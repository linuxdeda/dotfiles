# Force selection even if an app wants to capture the mouse
mouse-shift-capture = true

# Copy to clipboard immediately on select
copy-on-select = true
# --- Transparentnost ---
background-opacity = 0.81
background-blur-radius = 20

# Širina od 110 karaktera i visina od 30 redova
window-width = 150
window-height = 30

# --- Font ---
font-family = "JetBrains Mono"
font-size = 12

# --- Napredne opcije za font (opciono) ---
# Ovo omogućava "ligature" (npr. kada se -> pretvori u pravu strelicu)
font-feature = calt
font-feature = liga

# --- Prečice za Copy/Paste ---
# Ghostty koristi 'keybind' sistem. Ovim prebacujemo na tvoj željeni stil:
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

# --- Udaljenost teksta (Padding) ---
# Prvi broj je levo/desno, drugi je gore/dole
window-padding-x = 15
window-padding-y = 10

# --- Bonus: Da kursor ne treperi (opciono) ---
cursor-style = block
shell-integration-features = no-cursor
